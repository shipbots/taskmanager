# ─── Vercel Postgres ──────────────────────────────────────────────────────────
# Create in Vercel dashboard → Storage → Create → Postgres, then copy these from
# the database's ".env.local" tab (or run `vercel env pull`).
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ─── Vercel Blob (file attachments) ───────────────────────────────────────────
# Vercel dashboard → Storage → Create → Blob → copy the read/write token.
BLOB_READ_WRITE_TOKEN=

# ─── Google / NextAuth ────────────────────────────────────────────────────────
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
NEXTAUTH_SECRET=
# http://localhost:3100 for local dev (port 3100); your Vercel URL in production
NEXTAUTH_URL=http://localhost:3100
# Google OAuth credentials (console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: http://localhost:3100/api/auth/callback/google (+ prod URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Your email(s) — only these can sign in (comma-separated)
ALLOWED_EMAILS=

# ─── ShipBots mirror (pulls tasks from the Onboarding Dashboard) ──────────────
# Monday.com API key — the ShipBots project reads + writes its onboarding board
# and Clients board directly. Same key the Onboarding Dashboard uses.
MONDAY_API_KEY=
# Optional: deployed Onboarding Dashboard URL — used only for "open in onboarding" links.
ONBOARDING_API_BASE=
# Optional: your ShipBots assignee email(s), comma-separated (falls back to ALLOWED_EMAILS).
# Onboarding tasks assigned to anyone else are hidden from the ShipBots project.
SHIPBOTS_MY_EMAILS=

# ─── Smart notes (AI task drafting) ───────────────────────────────────────────
# Anthropic API key — console.anthropic.com → API Keys
SHIPBOTS_ANTHROPIC_KEY=
